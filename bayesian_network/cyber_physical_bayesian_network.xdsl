        <font color="000000" name="Arial" size="8" />
        <position>640 150 790 230</position>
        <barchart active="true" width="248" height="72" />
      </node>

      <node id="Queue_Drops">
        <name>Queue Drops</name>
        <interior color="fff2cc" />
        <outline color="7f6000" />
        <font color="000000" name="Arial" size="8" />
        <position>640 260 790 340</position>
        <barchart active="true" width="248" height="72" />
      </node>

      <node id="Routing_Drops">
        <name>Routing Drops</name>
        <interior color="fff2cc" />
        <outline color="7f6000" />
        <font color="000000" name="Arial" size="8" />
        <position>640 370 790 450</position>
        <barchart active="true" width="248" height="72" />
      </node>

      <node id="Control_Packets_Sent">
        <name>Control Packets Sent</name>
        <interior color="fff2cc" />
        <outline color="7f6000" />
        <font color="000000" name="Arial" size="8" />
        <position>350 450 500 530</position>
        <barchart active="true" width="248" height="72" />
      </node>

      <node id="Energy_Consumed_J">
        <name>Energy Consumption</name>
        <interior color="fff2cc" />
        <outline color="7f6000" />
        <font color="000000" name="Arial" size="8" />
        <position>60 370 210 450</position>
        <barchart active="true" width="248" height="72" />
      </node>
    </genie>
  </extensions>
</smile>